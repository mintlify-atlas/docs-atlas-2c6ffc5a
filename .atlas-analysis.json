  "keyFeatures": [
    "Fully static REST API — no server-side runtime required",
    "Complete hierarchical data: provinces → regencies → districts → villages",
    "Hosted on GitHub Pages — free, reliable, globally available",
    "PHP-based generator that converts CSV data files into thousands of JSON endpoints",
    "Fork-and-deploy model for self-hosting on your own GitHub account",
    "Approximately 100 million requests/month capacity via GitHub Pages bandwidth"
  ],
  "publicApiSurface": [
    "GET /api/provinces.json",
    "GET /api/province/{provinceId}.json",
    "GET /api/regencies/{provinceId}.json",
    "GET /api/regency/{regencyId}.json",
    "GET /api/districts/{regencyId}.json",
    "GET /api/district/{districtId}.json",
    "GET /api/villages/{districtId}.json",
    "GET /api/village/{villageId}.json"
  ]
